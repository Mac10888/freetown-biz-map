# Copy this file to .env and fill in your values

# Mapbox Configuration
REACT_APP_MAPBOX_TOKEN=pk.your-mapbox-token-here

# Nhost Configuration
# Either set the full GraphQL URL directly:
REACT_APP_NHOST_GRAPHQL_URL=https://your-subdomain.graphql.your-region.nhost.run/v1

# Or let the app build it from subdomain + region:
REACT_APP_NHOST_SUBDOMAIN=your-nhost-subdomain
REACT_APP_NHOST_REGION=your-nhost-region
